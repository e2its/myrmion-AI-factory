#!/usr/bin/env bash
# Generated by Agent: IMPLEMENT | Feature: EVOL-005
# ============================================================================
# pre-commit hook — Runs lightweight checks before each commit
# ============================================================================
# Checks:
#   1. Protected branch guard (prevent direct commits to main)
#   2. Secret leak detection (if gitleaks available)
#   3. Governance validation on staged governance files (if any changed)
# ============================================================================

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

# ── 1. Protected branch guard ──
CURRENT_BRANCH=$(git branch --show-current 2>/dev/null || echo "")
PROTECTED_BRANCHES="main master develop"
for branch in $PROTECTED_BRANCHES; do
  if [ "$CURRENT_BRANCH" = "$branch" ]; then
    echo -e "${RED}❌ Direct commits to '$branch' are blocked.${NC}"
    echo "   Create a feature branch: git checkout -b feature/YOUR-ID-description"
    exit 1
  fi
done

# ── 2. Secret leak detection (optional — skips if gitleaks not installed) ──
if command -v gitleaks &>/dev/null; then
  if ! gitleaks protect --staged --no-banner 2>/dev/null; then
    echo -e "${RED}❌ Potential secrets detected in staged files.${NC}"
    echo "   Review findings above and remove secrets before committing."
    exit 1
  fi
else
  # Silent skip — gitleaks is recommended but not required
  :
fi

# ── 3. Governance validation (only if governance files are staged) ──
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo "")
STAGED_FILES=$(git diff --cached --name-only)
GOVERNANCE_PATTERNS=".github/agents/ .github/instructions/ .github/skills/ .github/copilot-instructions.md .context/templates/setup/governance_versions.json"

GOVERNANCE_CHANGED=false
for pattern in $GOVERNANCE_PATTERNS; do
  if echo "$STAGED_FILES" | grep -qF "$pattern"; then
    GOVERNANCE_CHANGED=true
    break
  fi
done

GOVERNANCE_SCRIPT="${REPO_ROOT}/scripts/validate-governance.sh"
if [ "$GOVERNANCE_CHANGED" = true ] && [ -n "$REPO_ROOT" ] && [ -x "$GOVERNANCE_SCRIPT" ]; then
  echo -e "${YELLOW}🔍 Governance files changed — running validation...${NC}"
  if ! bash "$GOVERNANCE_SCRIPT" 2>/dev/null; then
    echo -e "${RED}❌ Governance validation failed. Fix issues before committing.${NC}"
    exit 1
  fi
  echo -e "${GREEN}✅ Governance validation passed.${NC}"
fi
