# ================================================
# SECRETS & ENVIRONMENT (MANDATORY - SECURITY)
# ================================================
# NEVER commit actual secrets. Use .env.example templates.
.env
.env.*
!.env.example
!.env.example.*
*.env
config/env/*
!config/env/.keep
config/secrets/*
!config/secrets/.keep
*.pem
*.key
*.p12
*.pfx


# Node/JS/TS
node_modules/
dist/
build/
.next/
.turbo/
.npm/
.pnpm-store/
*.tsbuildinfo

# Python
__pycache__/
*.pyc
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage*
coverage/

# Java
*.class
*.jar
*.war
*.nar
*.ear
target/
.mvn/

# C#/.NET
bin/
obj/
.vs/

# Logs
*.log
logs/

# ================================================
# CLAUDE CODE RUNTIME ARTIFACTS
# ================================================
# Session concurrency lock files (per-branch, transient)
.context/locks/
# Claude Code hook runtime state (PreCompact markers, future per-session transient state)
.claude/state/
# Machine-local permission overrides (auto-written by Claude Code, never commit)
.claude/settings.local.json

# ================================================
# FEATURE WORKFLOW ARTIFACTS (AGENTIC SDLC)
# ================================================
# QA reports are timestamped logs, not source-controlled
docs/spec/**/qa/qa_report_*.md
# Security audits are timestamped logs, not source-controlled
docs/spec/**/sec/sec_audit_*.md
# Temporary dev plans and execution logs
docs/spec/**/dev/execution_log_*.md

# ================================================
# CONTRACT DEVELOPMENT (MOCK ARTIFACTS)
# ================================================
contracts/mocks/.cache/
.spectral-cache/
contracts/**/*.backup
contracts/**/.generated/

# ================================================
# SECURITY SCANNING ARTIFACTS
# ================================================
.gitleaks-cache/
.semgrep_cache/
.trivy-cache/
security-reports/

# ================================================
# E2E TESTING ARTIFACTS (PLAYWRIGHT)
# ================================================
test-results/
playwright-report/
*.trace.zip
tests/e2e/specs/__snapshots__/

# ================================================
# DAST ARTIFACTS (OWASP ZAP)
# ================================================
security/dast/reports/
*.zap
zap-session-*
security/dast/.zap/

