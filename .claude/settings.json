{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/validate-governance.sh --banner"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/governance-onprompt.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/governance-oncompact.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-branch-protection.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check-concurrency-lock.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check-governance-drift.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-completion-gate.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check-ipp-compliance.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/governance-onedit.sh"
          }
        ]
      }
    ]
  }
}
