#!/usr/bin/env bash
# Generated by Agent: IMPLEMENT | Feature: EVOL-005
# ============================================================================
# commit-msg hook — Validates conventional commit message format
# ============================================================================
# Format: type(scope): description
# Types: feat, fix, docs, chore, refactor, test, perf, ci, style, build, revert
# Breaking: feat!, fix!, chore!, refactor! or BREAKING CHANGE: in body
# ============================================================================

set -euo pipefail

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(head -1 "$COMMIT_MSG_FILE")

# Skip merge commits and fixup/squash commits
SKIP_PATTERN='^(Merge |fixup! |squash! |amend! )'
if [[ "$COMMIT_MSG" =~ $SKIP_PATTERN ]]; then
  exit 0
fi

# Conventional commit regex:
#   type[(scope)][!]: description
#   - type: lowercase word
#   - scope: optional, any non-empty string in parens
#   - !: optional breaking change indicator
#   - description: starts with lowercase or number, non-empty
PATTERN='^(feat|fix|docs|chore|refactor|test|perf|ci|style|build|revert)(\([a-zA-Z0-9_./-]+\))?!?: .+'

if ! [[ "$COMMIT_MSG" =~ $PATTERN ]]; then
  echo "❌ Commit message does not follow Conventional Commits format."
  echo ""
  echo "Expected: type(scope): description"
  echo "Got:      $COMMIT_MSG"
  echo ""
  echo "Valid types: feat, fix, docs, chore, refactor, test, perf, ci, style, build, revert"
  echo "Examples:"
  echo "  feat(USR-001): add OAuth login flow"
  echo "  fix(BUG-042): resolve timeout in database query"
  echo "  chore(SETUP-001): initial project scaffolding"
  echo "  feat!: remove deprecated API endpoints"
  exit 1
fi
