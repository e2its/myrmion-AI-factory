#!/usr/bin/env bash
# Generated by Agent: IMPLEMENT | Feature: EVOL-005
# ============================================================================
# pre-push hook — Runs validation before pushing to remote
# ============================================================================
# Checks:
#   1. Protected branch enforcement (prevent force-push to main)
#   2. Full governance validation (if validate-governance.sh exists)
# ============================================================================

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

CURRENT_BRANCH=$(git branch --show-current 2>/dev/null || echo "")
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo "")

# ── 1. Block force-push to protected branches ──
PROTECTED_BRANCHES="main master develop"

# Check both the local branch and the remote ref destination
is_protected() {
  local ref="$1"
  for branch in $PROTECTED_BRANCHES; do
    if [ "$ref" = "$branch" ] || [ "$ref" = "refs/heads/$branch" ]; then
      return 0
    fi
  done
  return 1
}

# Read push info from stdin: <local ref> <local sha> <remote ref> <remote sha>
while read -r LOCAL_REF LOCAL_SHA REMOTE_REF REMOTE_SHA; do
  # Check if pushing TO a protected branch (via remote ref)
  if is_protected "$REMOTE_REF" || is_protected "$CURRENT_BRANCH"; then
    if [ "$REMOTE_SHA" != "0000000000000000000000000000000000000000" ] && \
       [ "$LOCAL_SHA" != "0000000000000000000000000000000000000000" ]; then
      # Check if this is a force push (local doesn't contain remote)
      if ! git merge-base --is-ancestor "$REMOTE_SHA" "$LOCAL_SHA" 2>/dev/null; then
        DEST=$(basename "$REMOTE_REF")
        echo -e "${RED}❌ Force-push to '$DEST' is blocked.${NC}"
        echo "   Use a feature branch and create a Pull Request."
        exit 1
      fi
    fi
  fi
done

# ── 2. Full governance validation (optional) ──
GOVERNANCE_SCRIPT="${REPO_ROOT}/scripts/validate-governance.sh"
if [ -n "$REPO_ROOT" ] && [ -x "$GOVERNANCE_SCRIPT" ]; then
  echo -e "${YELLOW}🔍 Running governance validation before push...${NC}"
  if ! bash "$GOVERNANCE_SCRIPT" 2>/dev/null; then
    echo -e "${RED}❌ Governance validation failed. Fix issues before pushing.${NC}"
    exit 1
  fi
  echo -e "${GREEN}✅ Governance validation passed.${NC}"
fi
