# ================================================
# SECRETS & ENVIRONMENT (MANDATORY - SECURITY)
# ================================================
# NEVER commit actual secrets. Use .env.example templates.
.env
.env.local
.env.*.local
!.env.example
!.env.example.*
config/secrets/*
!config/secrets/.keep
*.pem
*.key
*.p12
*.pfx

# ================================================
# ⚠️ SDLC FRAMEWORK — DO NOT COMMIT (IP PROTECTION)
# ================================================
# These files contain agentic workflows, governance logic, and internal tooling.
# They are synced from the framework via factory-sync.sh and must NOT be
# committed to project repositories.
# Copilot agent definitions, instructions, skills, prompts
.github/agents/
.github/instructions/
.github/skills/
.github/prompts/
.github/copilot-instructions.md
.github/workflow_sequence_v2.md
.github/review_retry_tracking.md
# Framework context (templates, schemas, utils, governance snapshot)
.context/
# Framework sync tool (lives in framework, not in project)
scripts/factory-sync.sh

